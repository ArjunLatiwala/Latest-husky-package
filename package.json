{
  "name": "cs-setup",
  "version": "1.1.0",
  "description": "Automatic Husky + Gitleaks + SonarQube setup for any JS project",
  "main": "bin/index.js",
  "bin": {
    "cs-setup": "./bin/index.js"
  },
  "keywords": [
    "husky",
    "gitleaks",
    "git-hooks",
    "security",
    "sonarqube"
  ],
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "postinstall": "node ./bin/index.js install",
    "prepare": "husky || true",
    "test": "npx --no-install cs-setup check-hooks 2>/dev/null || true && node --test"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "execa": "^5.1.1",
    "fs-extra": "^11.3.3",
    "husky": "^9.0.11",
    "sonarqube-scanner": "^4.0.0"
  },
  "files": [
    "bin/",
    "lib/",
    "templates/"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HUSAINTRIVEDI52/package_test.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3"
  }
}
